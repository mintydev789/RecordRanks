# Note: the `TZ` environment variable is crucial for date processing (i.e. validating dates, schedules, etc.).
# The time zone being set to UTC simplifies some of the date-related code (note that all dates are stored
# in UTC in the DB). This is only needed during local development, which is why it's included in this file.
#
# Code running client-side does not have this benefit and must account for the user's local time zone,
# since the Javascript Date object does not.
TZ=UTC

# Mostly the same as DATABASE_URL in the RR Docker Compose file
DATABASE_URL="postgresql://$RR_DB_USERNAME.$POOLER_TENANT_ID:$RR_DB_PASSWORD@localhost:$POOLER_PROXY_PORT_TRANSACTION/$POSTGRES_DB"