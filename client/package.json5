{
  name: 'record-ranks',
  type: 'module',
  private: true,
  scripts: {
    dev: "next dev -p $(grep -E '^NEXTJS_PORT=' .env | sed -r 's/^NEXTJS_PORT=([0-9]+).*/\\1/')",
    build: 'next build',
    start: 'next start',
    check: 'npx @biomejs/biome check',
    test: 'vitest run',
    'test:watch': 'vitest watch',
    'server-only-off': 'find "./" -type f -name "*.ts" -exec sed -i "s/^import \\"server-only\\";$/\\/\\/ import \\"server-only\\";/" {} +',
    'server-only-on': 'find "./" -type f -name "*.ts" -exec sed -i "s/^\\/\\/ import \\"server-only\\";$/import \\"server-only\\";/" {} +',
    // WHEN RUNNING DRIZZLE OR BETTER AUTH COMMANDS, USE THE TWO SCRIPTS ABOVE TO DISABLE AND THEN ENABLE "server-only" IMPORTS!
    'db:migrate': 'drizzle-kit migrate',
    'db:generate': 'drizzle-kit generate',
    'auth:migrate': 'npx auth migrate --config server/auth.ts',
    'auth:generate': 'npx auth generate --config server/auth.ts --output ./server/db/schema/auth-schema.ts',
  },
  dependencies: {
    '@better-auth/drizzle-adapter': '1.6.20',
    '@better-auth/stripe': '1.6.22',
    '@cubing/icons': '3.0.5',
    '@fortawesome/fontawesome-svg-core': '7.2.0',
    '@fortawesome/free-regular-svg-icons': '7.2.0',
    '@fortawesome/free-solid-svg-icons': '7.2.0',
    '@fortawesome/react-fontawesome': '3.3.1',
    '@mdx-js/loader': '3.1.1',
    '@mdx-js/react': '3.1.1',
    '@next/env': '16.2.9',
    '@next/mdx': '16.2.9',
    '@supabase/storage-js': '2.108.2',
    '@tanstack/react-virtual': '3.14.3',
    '@wca/helpers': '1.1.7',
    'better-auth': '1.6.20',
    bootstrap: '5.3.8',
    'country-flag-icons': '1.6.18',
    cubing: '0.63.3',
    'date-fns': '4.4.0',
    'date-fns-tz': '3.2.0',
    'drizzle-orm': '1.0.0-rc.3',
    'geo-tz': '8.1.7',
    handlebars: '4.7.9',
    jszip: '3.10.1',
    lodash: '4.18.1',
    next: '16.2.9',
    'next-safe-action': '8.5.5',
    nodemailer: '9.0.1',
    nuqs: '2.8.9',
    pino: '10.3.1',
    'pino-logflare': '0.5.2',
    postgres: '3.4.9',
    react: '19.2.7',
    'react-datepicker': '9.1.0',
    'react-dom': '19.2.7',
    'react-markdown': '10.1.0',
    'remove-accents': '0.5.0',
    'server-only': '0.0.1',
    stripe: '22.3.0',
    swr: '2.4.1',
    typescript: '5.9.3',
    zod: '4.4.3',
  },
  devDependencies: {
    '@biomejs/biome': '2.5.0',
    '@electric-sql/pglite': '0.5.3',
    '@types/lodash': '4.17.24',
    '@types/mdx': '2.0.14',
    '@types/node': '24.10.9',
    '@types/nodemailer': '8.0.1',
    '@types/pg': '8.20.0',
    '@types/react': '19.2.17',
    '@types/react-dom': '19.2.3',
    'drizzle-kit': '1.0.0-rc.3',
    vitest: '4.1.9',
  },
}
