{
  name: 'record-ranks',
  type: 'module',
  private: true,
  scripts: {
    dev: "next dev -p $(cat .env.development | grep -E '^NEXTJS_PORT=' | sed -r 's/^NEXTJS_PORT=([0-9]+).*/\\1/')",
    build: 'next build',
    start: 'next start',
    check: 'npx @biomejs/biome check',
    test: 'vitest run',
    'test:watch': 'vitest watch',
    'db:push': 'NODE_OPTIONS="--conditions=react-server" drizzle-kit push',
    'db:migrate': 'NODE_OPTIONS="--conditions=react-server" drizzle-kit migrate',
    'db:generate': 'NODE_OPTIONS="--conditions=react-server" drizzle-kit generate',
    'auth:migrate': 'auth migrate',
    // BEFORE RUNNING THIS COMMENT OUT THE "relations" PROPERTY IN THE DRIZZLE CONFIG OBJECT IN provider.ts
    'auth:generate': 'auth generate --output ./server/db/schema/auth-schema.ts',
  },
  dependencies: {
    '@better-auth/drizzle-adapter': '1.5.4',
    '@cubing/icons': '3.0.5',
    '@fortawesome/fontawesome-svg-core': '7.2.0',
    '@fortawesome/free-regular-svg-icons': '7.2.0',
    '@fortawesome/free-solid-svg-icons': '7.2.0',
    '@fortawesome/react-fontawesome': '3.2.0',
    '@mdx-js/loader': '3.1.1',
    '@mdx-js/react': '3.1.1',
    '@next/mdx': '16.1.6',
    '@supabase/storage-js': '2.99.0',
    '@tanstack/react-virtual': '3.13.21',
    '@wca/helpers': '1.1.7',
    'better-auth': '1.5.4',
    bootstrap: '5.3.8',
    'country-flag-icons': '1.6.15',
    cubing: '0.63.3',
    'date-fns': '4.1.0',
    'date-fns-tz': '3.2.0',
    'drizzle-orm': '1.0.0-beta.12-5845444',
    'geo-tz': '8.1.6',
    handlebars: '4.7.8',
    jszip: '3.10.1',
    lodash: '4.17.23',
    next: '16.1.6',
    'next-safe-action': '8.1.8',
    nodemailer: '8.0.2',
    pino: '10.3.1',
    'pino-logflare': '0.5.2',
    postgres: '3.4.8',
    react: '19.2.4',
    'react-datepicker': '9.1.0',
    'react-dom': '19.2.4',
    'react-markdown': '10.1.0',
    'remove-accents': '0.5.0',
    'server-only': '0.0.1',
    typescript: '5.9.3',
    zod: '4.3.6',
  },
  devDependencies: {
    '@biomejs/biome': '2.4.6',
    '@electric-sql/pglite': '0.3.15',
    '@next/env': '16.1.6',
    '@types/lodash': '4.17.24',
    '@types/mdx': '2.0.13',
    '@types/node': '24.10.9',
    '@types/nodemailer': '7.0.11',
    '@types/pg': '8.18.0',
    '@types/react': '19.2.14',
    '@types/react-dom': '19.2.3',
    'drizzle-kit': '1.0.0-beta.12-5845444',
    vitest: '4.0.18',
  },
}
